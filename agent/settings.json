    "extensions/pipeline-team.ts",
    "extensions/session-replay.ts",
    "extensions/subagent-widget.ts",
    "extensions/system-select.ts",
    "extensions/theme-cycler.ts",
    "extensions/tasks.ts",
    "extensions/commander-mcp.ts",
